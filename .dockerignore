# ============================================================
# Secrets & Credentials (NEVER include in Docker image)
# ============================================================
.env
.env.*
*.pem
*.key
secrets.json

# ============================================================
# History & Review (project-specific exclusions)
# ============================================================
.history/
review.md

# ============================================================
# Git
# ============================================================
.git/
.gitignore

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.egg
*.egg-info/
dist/
build/
venv/
.venv/
.mypy_cache/
.pytest_cache/
htmlcov/
.coverage

# ============================================================
# Node / Frontend
# ============================================================
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*

# ============================================================
# Docs (not needed inside container)
# ============================================================
docs/
README.md

# ============================================================
# OS / Editor
# ============================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*.log
